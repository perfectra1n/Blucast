#!/bin/bash
#
# BluCast launcher — installed to /usr/bin/blucast by the distro packages.
#
# Replaces the old run.sh. Unlike run.sh it performs NO privileged host
# mutation: the v4l2loopback module is loaded at boot by
# /usr/lib/modules-load.d/blucast.conf, the virtual camera is made
# user-accessible by a udev uaccess rule, and the virtual microphone is created
# declaratively by a PipeWire drop-in. This launcher only builds (on request)
# and runs the GPU container.
#
# Usage:
#   blucast                     Launch the app.
#   blucast --build [--sdk P]   Build the container image from the proprietary
#                               NVIDIA SDK at P (a sdk.tar.gz or an extracted
#                               sdk/ directory). Required once before first run.
#   blucast --help

set -euo pipefail

DATADIR="${BLUCAST_DATADIR:-/usr/share/blucast}"
SHARED_DIR="/tmp/blucast"
VCAM_DEVICE="/dev/video10"
MIC_SOURCE="BluCast_Virtual_Microphone"
LOCAL_IMAGE="localhost/blucast:latest"
# Optional maintainer-hosted image. Empty by default because the image bakes in
# the proprietary SDK and generally must NOT be redistributed publicly.
REMOTE_IMAGE="${BLUCAST_REMOTE_IMAGE:-}"

die()  { echo "blucast: $*" >&2; exit 1; }
info() { echo "blucast: $*"; }

# ── Container runtime ──────────────────────────────────────────────────────
if command -v podman &>/dev/null; then
    CONTAINER_CMD="podman"
elif command -v docker &>/dev/null; then
    CONTAINER_CMD="docker"
else
    die "podman or docker is required (install one and retry)."
fi

# ── Subcommand: build the image from a user-provided SDK ───────────────────
build_image() {
    local sdk=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --sdk) sdk="${2:-}"; shift 2 ;;
            --sdk=*) sdk="${1#--sdk=}"; shift ;;
            *) die "unknown build argument: $1" ;;
        esac
    done
    [ -n "$sdk" ] || sdk="$DATADIR/sdk.tar.gz"
    [ -e "$sdk" ] || die "SDK not found at '$sdk'. Pass --sdk=/path/to/sdk.tar.gz (or an extracted sdk/ dir)."
    [ -d "$DATADIR" ] || die "missing $DATADIR (is the package installed correctly?)."

    local ctx
    ctx="$(mktemp -d)"
    trap 'rm -rf "$ctx"' RETURN
    info "Assembling build context in $ctx ..."
    cp -r "$DATADIR/Containerfile" "$DATADIR/app" "$DATADIR/assets" "$ctx/"
    mkdir -p "$ctx/sdk"
    if [ -d "$sdk" ]; then
        cp -r "$sdk"/. "$ctx/sdk/"
    else
        tar -xzf "$sdk" -C "$ctx"   # expected to expand to ctx/sdk/...
        [ -d "$ctx/sdk/VideoFX" ] || die "SDK tarball did not expand to a sdk/ dir with VideoFX/AudioFX/TensorRT/cudnn."
    fi
    info "Building $LOCAL_IMAGE (this is large and may take a while)..."
    "$CONTAINER_CMD" build -t "$LOCAL_IMAGE" -f "$ctx/Containerfile" "$ctx"
    info "Image built. Launch with: blucast"
}

# ── Resolve the image to run ───────────────────────────────────────────────
resolve_image() {
    if "$CONTAINER_CMD" image exists "$LOCAL_IMAGE" 2>/dev/null || \
       "$CONTAINER_CMD" inspect "$LOCAL_IMAGE" &>/dev/null 2>&1; then
        echo "$LOCAL_IMAGE"; return 0
    fi
    if [ -n "$REMOTE_IMAGE" ]; then
        info "Pulling $REMOTE_IMAGE ..." >&2
        "$CONTAINER_CMD" pull "$REMOTE_IMAGE" >&2 && { echo "$REMOTE_IMAGE"; return 0; }
    fi
    die "no BluCast image found. Build it once with: blucast --build --sdk=/path/to/sdk.tar.gz"
}

case "${1:-}" in
    --build) shift; build_image "$@"; exit 0 ;;
    --help|-h)
        sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
esac

IMAGE_NAME="$(resolve_image)"

# ── Pre-flight: devices (no privilege escalation) ──────────────────────────
if [ ! -e "$VCAM_DEVICE" ]; then
    echo "blucast: virtual camera $VCAM_DEVICE not present." >&2
    echo "         It loads automatically at boot. Reboot, or load it once with:" >&2
    echo "           sudo modprobe v4l2loopback" >&2
    exit 1
fi

# ── Shared runtime dir + watchers ──────────────────────────────────────────
mkdir -p "$SHARED_DIR"
echo "0" > "$SHARED_DIR/consumers"
echo "0" > "$SHARED_DIR/audio_consumers"
rm -f "$SHARED_DIR/preview.jpg" "$SHARED_DIR/cmd.pipe"

WATCHER_PID=""; VMIC_WATCHER_PID=""
if [ -x "$DATADIR/scripts/vcam_watcher.sh" ]; then
    "$DATADIR/scripts/vcam_watcher.sh" "$VCAM_DEVICE" & WATCHER_PID=$!
fi
if [ -x "$DATADIR/scripts/vmic_watcher.sh" ]; then
    "$DATADIR/scripts/vmic_watcher.sh" "$MIC_SOURCE" & VMIC_WATCHER_PID=$!
fi

cleanup() {
    if [ -n "$WATCHER_PID" ]; then kill "$WATCHER_PID" 2>/dev/null || true; fi
    if [ -n "$VMIC_WATCHER_PID" ]; then kill "$VMIC_WATCHER_PID" 2>/dev/null || true; fi
    rm -f "$SHARED_DIR/consumers" "$SHARED_DIR/audio_consumers" \
          "$SHARED_DIR/preview.jpg" "$SHARED_DIR/cmd.pipe" \
          "$SHARED_DIR/server.pid" "$SHARED_DIR/.xauth"
}
trap cleanup EXIT

# ── Build the container run argument list (array → no word-split hazards) ───
RUN_ARGS=( --rm --security-opt label=disable )

if [ "$CONTAINER_CMD" = "podman" ]; then
    RUN_ARGS+=( --device nvidia.com/gpu=all )
else
    RUN_ARGS+=( --gpus all )
fi

for cam in /dev/video*; do
    [ -e "$cam" ] && RUN_ARGS+=( --device "$cam:$cam" )
done

RUN_ARGS+=(
    -e DISPLAY="${DISPLAY:-:0}"
    -e NVIDIA_DRIVER_CAPABILITIES=all
    -e NVIDIA_VISIBLE_DEVICES=all
    -e QT_QPA_PLATFORM=xcb
    -e QT_LOGGING_RULES="*.debug=false"
    -e XDG_RUNTIME_DIR=/tmp/runtime-root
    -v /tmp/.X11-unix:/tmp/.X11-unix:rw
)

# X11 cookie
XAUTH_FILE="$SHARED_DIR/.xauth"
if command -v xauth &>/dev/null && [ -n "${DISPLAY:-}" ]; then
    touch "$XAUTH_FILE"
    xauth nlist "$DISPLAY" 2>/dev/null | sed -e 's/^..../ffff/' \
        | xauth -f "$XAUTH_FILE" nmerge - 2>/dev/null || true
    if [ -s "$XAUTH_FILE" ]; then
        RUN_ARGS+=( -v "$XAUTH_FILE:/root/.Xauthority:ro" -e XAUTHORITY=/root/.Xauthority )
    fi
elif [ -n "${XAUTHORITY:-}" ] && [ -f "${XAUTHORITY:-}" ]; then
    RUN_ARGS+=( -v "$XAUTHORITY:/root/.Xauthority:ro" )
elif [ -f "$HOME/.Xauthority" ]; then
    RUN_ARGS+=( -v "$HOME/.Xauthority:/root/.Xauthority:ro" )
fi

# D-Bus session
if [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
    DBUS_SOCKET="${DBUS_SESSION_BUS_ADDRESS#unix:path=}"
    DBUS_SOCKET="${DBUS_SOCKET%%,*}"
    if [ -S "$DBUS_SOCKET" ]; then
        RUN_ARGS+=( -v "$DBUS_SOCKET:$DBUS_SOCKET" -e "DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS" )
    fi
fi

# Host audio socket (PULSE_SERVER works for both PulseAudio and PipeWire).
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
if [ -S "$RUNTIME_DIR/pulse/native" ]; then
    RUN_ARGS+=( -v "$RUNTIME_DIR/pulse/native:/tmp/pulse-native" -e PULSE_SERVER=unix:/tmp/pulse-native )
fi
[ -S "$RUNTIME_DIR/pipewire-0" ] && RUN_ARGS+=( -v "$RUNTIME_DIR/pipewire-0:/tmp/pipewire-0" )
[ -f "$HOME/.config/pulse/cookie" ] && RUN_ARGS+=( -v "$HOME/.config/pulse/cookie:/root/.config/pulse/cookie:ro" )

CONFIG_DIR="$HOME/.config/blucast"
mkdir -p "$CONFIG_DIR"
RUN_ARGS+=(
    -v "$HOME:/host_home:ro"
    -v "$CONFIG_DIR:/root/.config/blucast:rw"
    -v "$SHARED_DIR:$SHARED_DIR:rw"
    -v /dev/dri:/dev/dri
    --ipc=host
    --network host
)

xhost +local: 2>/dev/null || true

info "Starting BluCast..."
exec "$CONTAINER_CMD" run "${RUN_ARGS[@]}" "$IMAGE_NAME"
